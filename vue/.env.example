# ============================================================
# Vite 环境变量 — 复制为 .env 后修改
VITE_PROVIDER_MODE=standalone  # standalone=独立模式（解耦接口依赖）| remote=联调模式
# ============================================================
#
# Vue 前端与 dotnet 后端为独立项目，所有后端连接均通过环境变量配置。
# 开发时 Vite proxy 将 /api 转发到后端，生产部署时直接配置完整 URL。

# API 基址（开发/本地模式留空，API 路径自带 /api 前缀；生产部署填绝对 URL）
VITE_API_BASE_URL=

# IdentityServer (OIDC) 地址 — 须与后端 launchSettings.json 端口一致
VITE_OAUTH_AUTHORITY=https://localhost:44356

# OIDC 客户端 ID — 须与后端 IdentityServer 注册的 client_id 一致
VITE_OAUTH_CLIENT_ID=TodoApp_App

# 应用名称
VITE_APP_NAME=TodoApp

# 路由模式 — history=HTML5 History（需要服务端 SPA 回退）| hash=Hash 模式（# 号路径，无需服务端配置）
VITE_ROUTER_MODE=history

# ============================================================
# 生产部署时额外配置（可选）
# ============================================================
# VITE_API_BASE_URL=https://your-api.example.com
# VITE_OAUTH_AUTHORITY=https://your-auth.example.com
